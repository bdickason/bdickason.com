{
  "name": "bdickason.com",
  "version": "0.1.0",
  "description": "Static site for my personal stuff",
  "scripts": {
    "deploy": "npx vercel",
    "dev": "npm run validate && NODE_OPTIONS='--no-deprecation' npx @11ty/eleventy --serve",
    "preview": "npm run validate && NODE_OPTIONS='--no-deprecation' npx vercel dev",
    "new:video": "node scripts/new-post.mjs video",
    "new:blog": "node scripts/new-post.mjs blog",
    "new:inspiration": "node scripts/new-post.mjs inspiration",
    "validate": "node scripts/validate.mjs && npm run validate:starfield",
    "validate:starfield": "node scripts/validate-starfield-smoke.mjs && npm run test:starfield",
    "test:starfield": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --test static/experiments/starfield/*.test.mjs",
    "build": "npm run validate && NODE_OPTIONS='--no-deprecation' npx @11ty/eleventy",
    "clean": "rm -rf ./_site",
    "optimizeposts": "/Applications/ImageOptim.app/Contents/MacOS/ImageOptim ./static/posts",
    "optimizeall": "/Applications/ImageOptim.app/Contents/MacOS/ImageOptim ./static"
  },
  "engines": {
    "node": ">=22"
  },
  "author": "bdickason",
  "contributors": [
    {
      "name": "bdickason",
      "email": "dickason@gmail.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/bdickason/bdickason.com.git"
  },
  "dependencies": {
    "clean-css": "^4.2.3"
  },
  "license": "GPL-3.0",
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "gray-matter": "^4.0.3",
    "vercel": "^50.32.5"
  }
}
