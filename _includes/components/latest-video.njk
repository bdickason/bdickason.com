{% from 'components/youtube-embed.njk' import youtubeEmbed %}
{% set latest = collections.videoPosts[0] %}
{% if latest %}
<section class="latest-video" aria-labelledby="latest-video-heading">
  <h2 id="latest-video-heading">Latest video</h2>
  {{ youtubeEmbed(latest.data.videoId, latest.data.title, latest.data.startAt) }}
</section>
{% endif %}
