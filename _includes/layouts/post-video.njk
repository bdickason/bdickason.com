---
layout: layouts/base.njk
tags: post
---
{% from 'components/youtube-embed.njk' import youtubeEmbed %}
<article class="elv-layout post post-video">
	<h1>{{ title }}</h1>
	{% include 'components/date.njk' %}

	{{ youtubeEmbed(videoId, title, startAt) }}

	{% if summary %}
	<div class="video-summary">
		{{ summary | safe }}
	</div>
	{% endif %}

	{% if keyIdeas and keyIdeas.length %}
	<ul class="key-ideas">
		{% for idea in keyIdeas %}
		<li>{{ idea }}</li>
		{% endfor %}
	</ul>
	{% endif %}

	{% if content %}
	<div class="video-transcript">
		<h2>Transcript</h2>
		<div class="transcript-body">
			{{ content | safe }}
		</div>
	</div>
	{% endif %}

	
	{% include 'components/newsletter-cta.njk' %}

	{% include 'components/posts.njk' %}
</article>
