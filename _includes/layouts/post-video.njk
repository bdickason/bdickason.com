---
layout: layouts/base.njk
tags: post
---
<article class="elv-layout post post-video">
	<h1>{{ title }}</h1>
	{% include 'components/date.njk' %}

	<div class="video-embed">
		<iframe
			width="560"
			height="315"
			src="https://www.youtube.com/embed/{{ videoId }}"
			title="{{ title }}"
			frameborder="0"
			allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
			allowfullscreen
		></iframe>
	</div>

	{% if summary %}
	<div class="video-summary">
		{{ summary | safe }}
	</div>
	{% endif %}

	{% if keyIdeas and keyIdeas.length %}
	<ul class="key-ideas">
		{% for idea in keyIdeas %}
		<li>{{ idea }}</li>
		{% endfor %}
	</ul>
	{% endif %}

	{{ content | safe }}

	{% if transcript %}
	<div class="video-transcript">
		<h2>Notes</h2>
		<div class="transcript-body">
			{{ transcript | safe }}
		</div>
	</div>
	{% endif %}

	<p class="video-cta">
		If you liked this video, subscribe to my YouTube channel: <a href="https://www.youtube.com/@braddickason" target="_blank" rel="noopener">@braddickason</a>.
	</p>

	{% include 'components/posts.njk' %}
</article>
