<!doctype html>
{% set pageClass = 'has-starfield-bg' %}
{% if templateClass %}
	{% set pageClass = pageClass + ' ' + templateClass %}
{% endif %}
{% set hasStarfieldBg = true %}
<html lang="en" class="{{ pageClass }}">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">

		<title>{% if title and title != 'Home' %}{{ title }} | {{ site.siteName }}{% else %}{{ site.siteName }} — creativity, intuition & life{% endif %}</title>

		{% include 'components/head/seo.njk' %}

		{%- set css %}
		{% include 'css/index.css' %}
		{% endset %}
		<style>{{ css | cssmin | safe }}</style>

	</head>

	<body>
		<div id="starfield-bg" aria-hidden="true"></div>
		<div id="cursor-trails" aria-hidden="true"><canvas id="cursor-trails-canvas"></canvas></div>
		{% include 'components/nav.njk' %}
		<main class="elv-layout{% if layoutClass %} {{ layoutClass }}{% endif %}">
			{{ content | safe }}
			{% include 'components/footer.njk' %}
		</main>

		
		<div class="footer-iolo">
			<img src="/static/iolo-bg.png" 
				alt="Ruins glowing with spectral energy"
				class="iolo-bg" 
				decoding="async"
				loading="lazy"
				aria-hidden="true"
			/>
			<img src="/static/iolo-character.png" 
				alt="Iolo playing lute"
				class="iolo-character" 
				decoding="async"
				loading="lazy"
				aria-hidden="true"
			/>

			<div class="iolo-particles" aria-hidden="true"></div>
		</div>
		<section id="debug-panel" class="debug" hidden>
			<header class="debug__header">
				<div class="debug__title">Debug</div>
				<div class="debug__hint"><kbd>`</kbd> to toggle</div>
			</header>
			<div class="debug__row">
				<label class="debug__label" for="density">Density</label>
				<input id="density" class="debug__range" type="range" min="0" max="1" step="0.01" value="0.70" />
				<div class="debug__value" id="densityValue">0.70</div>
			</div>
			<div class="debug__row">
				<label class="debug__label" for="brightness">Brightness</label>
				<input
					id="brightness"
					class="debug__range"
					type="range"
					min="0"
					max="1"
					step="0.01"
					value="0.80"
				/>
				<div class="debug__value" id="brightnessValue">0.80</div>
			</div>
			<div class="debug__row">
				<label class="debug__label" for="direction">Direction</label>
				<select id="direction" class="debug__select">
					<option value="rtl">Right to left</option>
					<option value="into">Into the starfield</option>
				</select>
				<div class="debug__value" id="directionValue">rtl</div>
			</div>
			<div class="debug__row">
				<div class="debug__label">Perf</div>
				<div class="debug__value" id="perfFps" style="text-align:left">—</div>
				<div class="debug__value" id="perfLongTasks" title="Count of Long Tasks (when supported)">—</div>
			</div>
			<div class="debug__row">
				<div class="debug__label">Frame</div>
				<div class="debug__value" id="perfFrame" style="text-align:left">—</div>
				<div class="debug__value" id="perfDropped" title="Frames over 50ms">—</div>
			</div>
			<div class="debug__row">
				<label class="debug__label" for="ioloStrength">Iolo</label>
				<input id="ioloStrength" class="debug__range" type="range" min="0" max="1" step="0.01" value="0.65" />
				<div class="debug__value" id="ioloStrengthValue">0.65</div>
			</div>
		</section>

		<script type="text/javascript">
			(function () {
				try {
					// Keep initial load fast: only fetch Three.js if we plan to run starfield.
					var rm = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
					if (rm) return;

					var conn = navigator.connection;
					if (conn && (conn.saveData || (typeof conn.effectiveType === "string" && /(^|-)2g$/.test(conn.effectiveType)))) return;

					var importMap = document.createElement("script");
					importMap.type = "importmap";
					importMap.textContent = JSON.stringify({
						imports: {
							three: "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
							"three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/",
						},
					});
					document.head.appendChild(importMap);

					function load() {
						import("/static/js/starfield-bg.js").catch(function () {});
					}
					if ("requestIdleCallback" in window) window.requestIdleCallback(load, { timeout: 2500 });
					else setTimeout(load, 800);
				} catch (e) {
					// ignore
				}
			})();
		</script>

		{%- set js %}
		{% include 'js/convertkit.js' %}
		{% include 'js/neon-headings.js' %}
		{% include 'js/scanline-photons.js' %}
		{% include 'js/cursor-trails.js' %}
		{% include 'js/footer-iolo.js' %}
		{% endset %}
		<script type="text/javascript">{{ js | safe }}</script>
	</body>
</html>
