---
layout: layouts/base.njk
tags: post
---
<article class="elv-layout">
  <h1>{{ title }}</h1>

  {% include 'components/date.njk' %}

  <div class="video-embed">
    <iframe
      width="560"
      height="315"
      src="https://www.youtube.com/embed/{{ videoId }}"
      title="{{ title }}"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>

  {% if summary %}
  <div class="video-summary">
    {{ summary }}
  </div>
  {% endif %}

  {% if transcript %}
  <div class="video-transcript">
    <h2>Notes</h2>
    {{ transcript | safe }}
  </div>
  {% endif %}

  {{ content | safe }}

  <p class="video-cta">
    If you liked this video, subscribe to my YouTube channel: <a href="https://www.youtube.com/@bdickason" target="_blank" rel="noopener">@bdickason</a>.
  </p>

  {% include 'components/posts.njk' %}
</article>
